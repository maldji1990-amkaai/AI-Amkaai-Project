{
  "name": "amkaai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:push": "prisma db push",
    "worker": "tsx --env-file=.env.local workers/video.worker.ts",
    "worker:dev": "tsx watch --env-file=.env.local workers/video.worker.ts",
    "clean": "rm -rf node_modules .next",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@clerk/nextjs": "^7.2.2",
    "@prisma/client": "^6.19.3",
    "@upstash/redis": "^1.38.0",
    "bullmq": "^5.76.8",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "imghash": "^1.1.4",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.453.0",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "radix-ui": "^1.4.3",
    "raw-body": "^3.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-qr-code": "^2.0.18",
    "recharts": "^3.8.1",
    "replicate": "^1.4.0",
    "resend": "^6.12.2",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tesseract.js": "^7.0.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "nodemon": "^3.1.0",
    "postcss": "^8.5.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.0",
    "typescript": "^5"
  }
